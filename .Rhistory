install.packages("roxygen2")
g <- new("Genome",
genomeName = "Ecoli",
numChromosomes = 1,
numProteins = 4300)
setClass(
"Genome",
slots = list(
genomeName = "character",
numChromosomes = "numeric",
numProteins = "numeric"
)
)
# Method to calculate average proteins per chromosome
setGeneric("avgProteinPerCh", function(object) {
standardGeneric("avgProteinPerCh")
})
setMethod(
"avgProteinPerCh",
"Genome",
function(object) {
avg <- object@numProteins / object@numChromosomes
return(round(avg))
}
)
g <- new("Genome",
genomeName = "Ecoli",
numChromosomes = 1,
numProteins = 4300)
avgProteinPerCh(g)
