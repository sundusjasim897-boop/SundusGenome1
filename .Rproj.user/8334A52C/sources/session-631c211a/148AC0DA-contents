#' @title Genome S4 Class
#' @description An S4 class representing a genome with basic genomic information.
#'
#' @slot genome_name A character string giving the name of the genome.
#' @slot total_chromosomes A numeric value for the total number of chromosomes.
#' @slot total_proteins A numeric value for the total number of proteins.
#'
#' @examples
#' human <- new("Genome",
#'              genome_name = "Human",
#'              total_chromosomes = 23,
#'              total_proteins = 20000)
#'
#' @export
setClass(
  "Genome",
  representation(
    genome_name      = "character",
    total_chromosomes = "numeric",
    total_proteins   = "numeric"
  )
)

#' @title avgProteinPerCh
#' @description Computes the average number of proteins per chromosome,
#'   rounded to the nearest integer.
#'
#' @param object A \code{Genome} object.
#' @return An integer representing the average proteins per chromosome.
#'
#' @examples
#' human <- new("Genome",
#'              genome_name = "Human",
#'              total_chromosomes = 23,
#'              total_proteins = 20000)
#' avgProteinPerCh(human)
#'
#' @export
setGeneric("avgProteinPerCh", function(object) {
  standardGeneric("avgProteinPerCh")
})

#' @rdname avgProteinPerCh
setMethod("avgProteinPerCh", "Genome", function(object) {
  avg <- object@total_proteins / object@total_chromosomes
  return(round(avg))
})
